# ============================================================
#  SpendWise — Environment Variables (Railway Deployment)
#  Set these in Railway Dashboard → Variables
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=production
TZ=Asia/Kolkata

# --- MongoDB ---
# Use MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/spendwise?retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=change_this_to_a_long_random_secret_string_minimum_32_chars
ACCESS_TOKEN_EXPIRES=15m

# --- Redis (optional — app works without it) ---
# Add a Railway Redis service or leave blank
REDIS_URL=

# --- CORS ---
# Set this to your Railway app URL after deployment
CLIENT_URL=https://your-app-name.up.railway.app

# --- Email (Nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=SpendWise <your@gmail.com>

# --- Google Gemini AI (optional) ---
GEMINI_API_KEY=your_gemini_api_key
